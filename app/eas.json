{
  "cli": {
    "version": ">= 19.1.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://restaurant-app-web.onrender.com/api",
        "EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK": "1"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GRADLE_OPTS": "-Xmx4g -XX:MaxMetaspaceSize=1g -Dorg.gradle.parallel=false -Dorg.gradle.daemon=false",
        "EXPO_PUBLIC_API_URL": "https://restaurant-app-web.onrender.com/api",
        "EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK": "1"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://restaurant-app-web.onrender.com/api",
        "EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
